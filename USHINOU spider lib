        CreateTween({P, "BackgroundTransparency", 0.2, 0.8})

        table.insert(ActiveParticles, {
            Frame = P,
            StartTime = tick(),
            Speed = speed,
        })
    end

    local function UpdateParticles()
        for i = #ActiveParticles, 1, -1 do
            local p = ActiveParticles[i]
            local elapsed = tick() - p.StartTime
            if elapsed >= PConfig.Life or p.Frame.Position.Y.Offset < -20 then
                CreateTween({p.Frame, "BackgroundTransparency", 1, 0.4})
                task.spawn(function()
                    task.wait(0.4)
                    if p.Frame and p.Frame.Parent then p.Frame:Destroy() end
                end)
                table.remove(ActiveParticles, i)
            else
                local pos = p.Frame.Position
                p.Frame.Position = UDim2.fromOffset(pos.X.Offset, pos.Y.Offset - p.Speed * 0.016)
                local ratio = elapsed / PConfig.Life
                if ratio > 0.8 then
                    p.Frame.BackgroundTransparency = math.max(1 - (0.2 * (1 - ((ratio - 0.8) / 0.2))), 0.95)
                end
            end
        end
    end

