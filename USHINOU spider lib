    local function CreateParticle()
        if #ActiveParticles >= PConfig.MaxParticles then return end
        local cSize = ParticleContainer.AbsoluteSize
        local startX = math.random(10, math.max(10, cSize.X - 10))
        local size = math.random(PConfig.SizeMin, PConfig.SizeMax)
        local speed = math.random(PConfig.SpeedMin, PConfig.SpeedMax)

        local colors = {
            Color3.fromRGB(180, 180, 190),
            Color3.fromRGB(140, 140, 155),
            Color3.fromRGB(200, 200, 210),
            Color3.fromRGB(130, 130, 150),
        }
        local pColor = colors[math.random(1, #colors)]

        local P = Create("Frame", ParticleContainer, {
            Size = UDim2.fromOffset(size, size),
