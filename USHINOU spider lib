                TS:Create(DialBG, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
                    Size = UDim2.fromOffset(30, 30),
                    BackgroundTransparency = 1,
                }):Play()
                task.delay(0.2, function() DialOverlay.Visible = false end)
            end)
            if OmniBtn then
                TS:Create(OmniBtn, TweenInfo.new(0.2), { BackgroundColor3 = Color3.fromRGB(12, 12, 18) }):Play()
            end
        end

        UserInputService.InputBegan:Connect(function(inp)
            local focused = UserInputService:GetFocusedTextBox()
            if focused then return end
            
            if inp.KeyCode == Enum.KeyCode.N then
                if isOpen then closeDialFn() else openDialFn() end
            end
        end)
    end

    return Window
end

return redzlib
