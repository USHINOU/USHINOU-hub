                AnchorPoint = Vector2.new(1, 0.5),
                BackgroundTransparency = 1,
                Font = Enum.Font.GothamBold,
                TextSize = 9,
                TextColor3 = Theme["Color Text"],
                Text = tostring(Default)
            }), "Text")

            local CurrentValue = Default
            local function SetSlider(val)
                val = math.clamp(math.round(val / Increase) * Increase, Min, Max)
                CurrentValue = val
                SetFlag(Flag, val)
                local ratio = (val - Min) / (Max - Min)
                CreateTween({SliderIcon, "Position", UDim2.new(ratio, 0, 0.5), 0.2})
                CreateTween({SliderFill, "Size", UDim2.fromScale(ratio, 1), 0.2})
                LabelVal.Text = tostring(val)
                Funcs:FireCallback(Callback, val)
            end

            local GlobalSliderDrag = nil
            SliderBar.InputBegan:Connect(function(Input)
                if _GlobalSliderLock == nil and (Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch) then
                    _GlobalSliderLock = {Bar = SliderBar, InputType = Input.UserInputType}
                    local p = Container
                    while p do
                        if p:IsA("ScrollingFrame") then p.ScrollingEnabled = false end
                        p = p.Parent
                    end
                    local AbsPos = SliderBar.AbsolutePosition.X
                    local AbsSize = SliderBar.AbsoluteSize.X
                    local ratio = math.clamp((Input.Position.X - AbsPos) / AbsSize, 0, 1)
                    SetSlider(Min + (Max - Min) * ratio)
                end
            end)
            UserInputService.InputEnded:Connect(function(Input)
                if _GlobalSliderLock and _GlobalSliderLock.Bar == SliderBar and _GlobalSliderLock.InputType == Input.UserInputType then
                    _GlobalSliderLock = nil
                    local p = Container
                    while p do
                        if p:IsA("ScrollingFrame") then p.ScrollingEnabled = true end
                        p = p.Parent
                    end
                end
            end)
            UserInputService.InputChanged:Connect(function(Input)
                if _GlobalSliderLock and _GlobalSliderLock.Bar == SliderBar and _GlobalSliderLock.InputType == Input.UserInputType and (Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch) then
                    local AbsPos = SliderBar.AbsolutePosition.X
                    local AbsSize = SliderBar.AbsoluteSize.X
                    local ratio = math.clamp((Input.Position.X - AbsPos) / AbsSize, 0, 1)
                    SetSlider(Min + (Max - Min) * ratio)
                end
            end)

            SetSlider(Default)

            local Slider = {}
            function Slider:Visible(...) Funcs:ToggleVisible(Button, ...) end
            function Slider:Destroy() Button:Destroy() end
            function Slider:Set(Val)
                if type(Val) == "number" then SetSlider(Val)
                elseif type(Val) == "string" then LF:SetTitle(Val) end
            end
            return Slider
        end

