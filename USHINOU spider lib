local _BorderGradients = {}
local _BorderLoopStarted = false
local function _StartBorderLoop()
    if _BorderLoopStarted then return end
    _BorderLoopStarted = true
    game:GetService("RunService").Heartbeat:Connect(function(dt)
        local step = 80 * dt
        for i = #_BorderGradients, 1, -1 do
            local g = _BorderGradients[i]
            if g and g.Parent then
                g.Rotation = (g.Rotation + step) % 360
            else
                table.remove(_BorderGradients, i)
            end
        end
    end)
end

local function AddBorder(Target, Thickness)
    if not Target or Target:FindFirstChildOfClass("UIStroke") then return end
    local S = Instance.new("UIStroke", Target)
    S.Thickness = Thickness or 1.4
    S.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    S.LineJoinMode = Enum.LineJoinMode.Round
    local G = Instance.new("UIGradient", S)
    G.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0,   Color3.fromRGB(50, 40, 0)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(210, 210, 220)),
        ColorSequenceKeypoint.new(1,   Color3.fromRGB(50, 40, 0)),
    }
    table.insert(_BorderGradients, G)
    _StartBorderLoop()
    return S
end
