    local function AutoApplyRotatingBorders(Speed)
        Speed = Speed or 80
        local BorderGradients = {}
        local BorderLoopStarted = false

        local function StartLoop()
            if BorderLoopStarted then return end
            BorderLoopStarted = true
            RunService.Heartbeat:Connect(function(dt)
                for i = #BorderGradients, 1, -1 do
                    local G = BorderGradients[i]
                    if not G or not G.Parent then
                        table.remove(BorderGradients, i)
                    else
                        G.Rotation = (G.Rotation + Speed * dt) % 360
                    end
                end
            end)
        end

        local function AddBorderLocal(Target, Thickness)
            if not Target or Target:FindFirstChildOfClass("UIStroke") then return end
            local Stroke = Instance.new("UIStroke", Target)
            Stroke.Thickness = Thickness or 1.6
            Stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
            Stroke.Color = Color3.new(1, 1, 1)
            local Gradient = Instance.new("UIGradient", Stroke)
            Gradient.Color = ColorSequence.new{
                ColorSequenceKeypoint.new(0,   Theme["Color Theme"]),
                ColorSequenceKeypoint.new(0.5, Theme["Color Stroke"]),
                ColorSequenceKeypoint.new(1,   Color3.fromRGB(0, 0, 0)),
            }
            table.insert(BorderGradients, Gradient)
            StartLoop()
            return Stroke
        end

