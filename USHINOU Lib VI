        function Tab:AddSlider(Configs2)
            local SName2 = Configs2[1] or Configs2.Name or Configs2.Title or "Slider"
            local SDesc = Configs2.Desc or Configs2.Description or ""
            local Min = Configs2[2] or Configs2.Min or 0
            local Max = Configs2[3] or Configs2.Max or 100
            local Default = Configs2[4] or Configs2.Default or Min
            local Increase = Configs2[5] or Configs2.Increase or 1
            local Flag = Configs2.Flag or false
            local Callback = Funcs:GetCallback(Configs2, 6)
            if CheckFlag(Flag) then Default = GetFlag(Flag) end

            local Button, LF = ButtonFrame(Container, SName2, SDesc, UDim2.new(1, -90))

            local SliderBar = InsertTheme(Create("Frame", Button, {
                Size = UDim2.new(0, 130, 0, 14),
                Position = UDim2.new(1, -10, 0.5),
                AnchorPoint = Vector2.new(1, 0.5),
                BackgroundColor3 = Theme["Color Stroke"]
            }), "Stroke")
            Make("Corner", SliderBar, UDim.new(0.5, 0))

            local SliderFill = InsertTheme(Create("Frame", SliderBar, {
                Size = UDim2.fromScale(0, 1),
                BackgroundColor3 = Theme["Color Theme"],
                ClipsDescendants = true
            }), "Theme")
            Make("Corner", SliderFill, UDim.new(0.5, 0))

            local SliderIcon = Create("Frame", SliderBar, {
                Size = UDim2.new(0, 12, 0, 12),
                AnchorPoint = Vector2.new(0.5, 0.5),
                Position = UDim2.new(0, 0, 0.5),
                BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            })
            Make("Corner", SliderIcon, UDim.new(0.5, 0))

            local LabelVal = InsertTheme(Create("TextLabel", Button, {
                Size = UDim2.new(0, 30, 0, 14),
                Position = UDim2.new(1, -143, 0.5),
                AnchorPoint = Vector2.new(1, 0.5),
                BackgroundTransparency = 1,
                Font = Enum.Font.GothamBold,
                TextSize = 9,
                TextColor3 = Theme["Color Text"],
                Text = tostring(Default)
            }), "Text")

            local CurrentValue = Default
            local function SetSlider(val)
                val = math.clamp(math.round(val / Increase) * Increase, Min, Max)
                CurrentValue = val
                SetFlag(Flag, val)
                local ratio = (val - Min) / (Max - Min)
                CreateTween({SliderIcon, "Position", UDim2.new(ratio, 0, 0.5), 0.2})
                CreateTween({SliderFill, "Size", UDim2.fromScale(ratio, 1), 0.2})
                LabelVal.Text = tostring(val)
                Funcs:FireCallback(Callback, val)
            end

            local GlobalSliderDrag = nil
            SliderBar.InputBegan:Connect(function(Input)
                if _GlobalSliderLock == nil and (Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch) then
                    _GlobalSliderLock = {Bar = SliderBar, InputType = Input.UserInputType}
                    local p = Container
                    while p do
                        if p:IsA("ScrollingFrame") then p.ScrollingEnabled = false end
                        p = p.Parent
                    end
                    local AbsPos = SliderBar.AbsolutePosition.X
                    local AbsSize = SliderBar.AbsoluteSize.X
                    local ratio = math.clamp((Input.Position.X - AbsPos) / AbsSize, 0, 1)
                    SetSlider(Min + (Max - Min) * ratio)
                end
            end)
            UserInputService.InputEnded:Connect(function(Input)
                if _GlobalSliderLock and _GlobalSliderLock.Bar == SliderBar and _GlobalSliderLock.InputType == Input.UserInputType then
                    _GlobalSliderLock = nil
                    local p = Container
                    while p do
                        if p:IsA("ScrollingFrame") then p.ScrollingEnabled = true end
                        p = p.Parent
                    end
                end
            end)
            UserInputService.InputChanged:Connect(function(Input)
                if _GlobalSliderLock and _GlobalSliderLock.Bar == SliderBar and _GlobalSliderLock.InputType == Input.UserInputType and (Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch) then
                    local AbsPos = SliderBar.AbsolutePosition.X
                    local AbsSize = SliderBar.AbsoluteSize.X
                    local ratio = math.clamp((Input.Position.X - AbsPos) / AbsSize, 0, 1)
                    SetSlider(Min + (Max - Min) * ratio)
                end
            end)

            SetSlider(Default)

            local Slider = {}
            function Slider:Visible(...) Funcs:ToggleVisible(Button, ...) end
            function Slider:Destroy() Button:Destroy() end
            function Slider:Set(Val)
                if type(Val) == "number" then SetSlider(Val)
                elseif type(Val) == "string" then LF:SetTitle(Val) end
            end
            return Slider
        end

        function Tab:AddDropdown(Configs2)
            local DName = Configs2[1] or Configs2.Name or Configs2.Title or "Dropdown"
            local DDesc = Configs2.Desc or Configs2.Description or ""
            local DOptions = Configs2[2] or Configs2.Options or {}
            local DDefault = Configs2[3] or Configs2.Default or (DOptions[1] or "")
            local Flag = Configs2.Flag or false
            local Callback = Funcs:GetCallback(Configs2, 4)
            local IsMulti = Configs2.MultiSelect == true
            local MaxSelect = Configs2.MaxSelect or 999

            -- MultiSelect: Selected = table, Single: Selected = value
            local Selected = IsMulti and {} or (CheckFlag(Flag) and GetFlag(Flag) or DDefault)

            local Button, LF = ButtonFrame(Container, DName, DDesc, UDim2.new(1, -80))

            local SelectedFrame = InsertTheme(Create("Frame", Button, {
                Size = UDim2.new(0, 75, 0, 18),
                Position = UDim2.new(1, -10, 0.5),
                AnchorPoint = Vector2.new(1, 0.5),
                BackgroundColor3 = Theme["Color Stroke"]
            }), "Stroke")
            Make("Corner", SelectedFrame, UDim.new(0, 5))

            local ActiveLabel = InsertTheme(Create("TextLabel", SelectedFrame, {
                Size = UDim2.new(1, -20, 1),
                Position = UDim2.new(0, 5),
                BackgroundTransparency = 1,
                Font = Enum.Font.GothamBold,
                TextSize = 8,
                TextColor3 = Theme["Color Text"],
                TextTruncate = "AtEnd",
                Text = IsMulti and "اختار..." or tostring(Selected or "...")
            }), "Text")

            local Arrow = Create("ImageLabel", SelectedFrame, {
                Size = UDim2.new(0, 12, 0, 12),
                Position = UDim2.new(1, -2, 0.5),
                AnchorPoint = Vector2.new(1, 0.5),
                BackgroundTransparency = 1,
                Image = "rbxassetid://10709791523"
            })

            local NoClickFrame = Create("TextButton", ScreenGui, {
                Name = "AntiClick",
                Size = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Visible = false,
                Text = ""
            })

            local DropFrame = Create("Frame", NoClickFrame, {
                Size = UDim2.fromOffset(152, 0),
                BackgroundTransparency = 0.1,
                BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                AnchorPoint = Vector2.new(0, 1),
                Name = "DropdownFrame",
                ClipsDescendants = true,
                Active = true
            })
            Make("Corner", DropFrame)
            Make("Stroke", DropFrame)
            Make("Gradient", DropFrame, {Rotation = 60})

            local ScrollFrame = InsertTheme(Create("ScrollingFrame", DropFrame, {
                ScrollBarImageColor3 = Theme["Color Theme"],
                Size = UDim2.new(1, 0, 1, 0),
                ScrollBarThickness = 1.5,
                BackgroundTransparency = 1,
                BorderSizePixel = 0,
                CanvasSize = UDim2.new(),
                ScrollingDirection = "Y",
                AutomaticCanvasSize = "Y",
                Active = true
            }, {
                Create("UIPadding", {
                    PaddingLeft = UDim.new(0, 8),
                    PaddingRight = UDim.new(0, 8),
                    PaddingTop = UDim.new(0, 5),
                    PaddingBottom = UDim.new(0, 5)
                }),
                Create("UIListLayout", { Padding = UDim.new(0, 4) })
            }), "ScrollBar")

            local ScrollSize, WaitClick2 = 5

            local function Disable()
                WaitClick2 = true
                CreateTween({Arrow, "Rotation", 0, 0.2})
                CreateTween({DropFrame, "Size", UDim2.fromOffset(152, 0), 0.2, true})
                Arrow.Image = "rbxassetid://10709791523"
                NoClickFrame.Visible = false
                WaitClick2 = false
            end

            local function GetFrameSize() return UDim2.fromOffset(152, ScrollSize) end

            local function CalculateSize()
                local Count = 0
                for _, Frame in pairs(ScrollFrame:GetChildren()) do
                    if Frame:IsA("Frame") or Frame.Name == "Option" then Count = Count + 1 end
                end
                ScrollSize = (math.clamp(Count, 0, 10) * 25) + 10
            end

            local function CalculatePos()
                local FramePos = SelectedFrame.AbsolutePosition
                local ScreenSize = ScreenGui.AbsoluteSize
                local ClampX = math.clamp((FramePos.X / UIScale), 0, ScreenSize.X / UIScale - DropFrame.Size.X.Offset)
                local ClampY = math.clamp((FramePos.Y / UIScale), 0, ScreenSize.Y / UIScale)
                DropFrame.AnchorPoint = Vector2.new(0, FramePos.Y > ScreenSize.Y / 1.4 and 1 or 0)
                CreateTween({DropFrame, "Position", UDim2.fromOffset(ClampX, ClampY), 0.1})
            end

            local function Minimize()
                if WaitClick2 then return end
                WaitClick2 = true
                if NoClickFrame.Visible then
                    Arrow.Image = "rbxassetid://10709791523"
                    CreateTween({Arrow, "ImageColor3", Color3.fromRGB(255, 255, 255), 0.2})
                    CreateTween({DropFrame, "Size", UDim2.fromOffset(152, 0), 0.2, true})
                    NoClickFrame.Visible = false
                else
                    NoClickFrame.Visible = true
                    Arrow.Image = "rbxassetid://10709790948"
                    CreateTween({Arrow, "ImageColor3", Theme["Color Theme"], 0.2})
                    CalculateSize()
                    CreateTween({DropFrame, "Size", GetFrameSize(), 0.2, true})
                end
                WaitClick2 = false
            end

            -- دالة تحديث النص في الزر الرئيسي (للمولتي)
            local function UpdateMultiLabel()
                local count = 0
                for _ in pairs(Selected) do count = count + 1 end
                if count == 0 then
                    ActiveLabel.Text = "اختار..."
                else
                    ActiveLabel.Text = count .. " مختار"
                end
            end

            local Options = {}
            local function AddOption(index, Value)
                local Name = tostring(type(index) == "string" and index or Value)
                if Options[Name] then return end
                Options[Name] = { Value = Value, Name = Name }

                local Btn = Make("Button", ScrollFrame, {
                    Name = "Option",
                    Size = UDim2.new(1, 0, 0, 21),
                })
                Make("Corner", Btn, UDim.new(0, 4))

                local IsSelectedDot = InsertTheme(Create("Frame", Btn, {
                    Position = UDim2.new(0, 1, 0.5),
                    Size = UDim2.new(0, 4, 0, 4),
                    BackgroundColor3 = Theme["Color Theme"],
                    BackgroundTransparency = 1,
                    AnchorPoint = Vector2.new(0, 0.5)
                }), "Theme")
                Make("Corner", IsSelectedDot, UDim.new(0.5, 0))

                local OpLabel = InsertTheme(Create("TextLabel", Btn, {
                    Size = UDim2.new(1, 0, 1),
                    Position = UDim2.new(0, 10),
                    Text = Name,
                    TextColor3 = Theme["Color Text"],
                    Font = Enum.Font.GothamBold,
                    TextXAlignment = "Left",
                    BackgroundTransparency = 1,
                    TextTransparency = 0.4
                }), "Text")

                Options[Name].nodes = {Btn, IsSelectedDot, OpLabel}

                Btn.Activated:Connect(function()
                    if IsMulti then
                        -- MultiSelect: toggle الاختيار
                        if Selected[Name] then
                            -- شيله
                            Selected[Name] = nil
                            CreateTween({IsSelectedDot, "BackgroundTransparency", 1, 0.3})
                            CreateTween({IsSelectedDot, "Size", UDim2.fromOffset(4, 4), 0.3})
                            CreateTween({OpLabel, "TextTransparency", 0.4, 0.3})
                        else
                            -- احسب عدد المختارين
                            local count = 0
                            for _ in pairs(Selected) do count = count + 1 end
                            if count >= MaxSelect then return end
                            -- ضيفه
                            Selected[Name] = Value
                            CreateTween({IsSelectedDot, "BackgroundTransparency", 0, 0.3})
                            CreateTween({IsSelectedDot, "Size", UDim2.fromOffset(4, 14), 0.3})
                            CreateTween({OpLabel, "TextTransparency", 0, 0.3})
                            -- اسكر الـ dropdown تلقائي لو وصل MaxSelect
                            local newCount2 = 0
                            for _ in pairs(Selected) do newCount2 = newCount2 + 1 end
                            if newCount2 >= MaxSelect then
                                task.delay(0.15, Disable)
                            end
                        end
                        UpdateMultiLabel()
                        -- ارسل table من القيم للـ Callback
                        local result = {}
                        for _, v in pairs(Selected) do table.insert(result, v) end
                        Funcs:FireCallback(Callback, result)
                    else
                        -- Single select (الأصلي)
                        Selected = Value
                        ActiveLabel.Text = tostring(Selected)
                        SetFlag(Flag, tostring(Selected))
                        Funcs:FireCallback(Callback, Selected)
                        for _, op in pairs(Options) do
                            local isSel = op.Value == Selected
                            CreateTween({op.nodes[2], "BackgroundTransparency", isSel and 0 or 1, 0.3})
                            CreateTween({op.nodes[2], "Size", isSel and UDim2.fromOffset(4, 14) or UDim2.fromOffset(4, 4), 0.3})
                            CreateTween({op.nodes[3], "TextTransparency", isSel and 0 or 0.4, 0.3})
                        end
                        Disable()
                    end
                end)
            end

            for _, v in pairs(DOptions) do AddOption(v, v) end
            if not IsMulti then
                ActiveLabel.Text = tostring(Selected or "...")
            end

            Button.Activated:Connect(Minimize)
            NoClickFrame.MouseButton1Down:Connect(Disable)
            SelectedFrame:GetPropertyChangedSignal("AbsolutePosition"):Connect(CalculatePos)
            CalculatePos()
            CalculateSize()

            local Dropdown = {}
            function Dropdown:Visible(...) Funcs:ToggleVisible(Button, ...) end
            function Dropdown:Destroy() Button:Destroy() end
            function Dropdown:Add(NewOpts)
                -- حذف الخيارات القديمة من UI و Options
                for name, op in pairs(Options) do
                    if op.nodes and op.nodes[1] then
                        op.nodes[1]:Destroy()
                    end
                end
                Options = {}
                if IsMulti then
                    Selected = {}
                    UpdateMultiLabel()
                else
                    Selected = ""
                    ActiveLabel.Text = "..."
                end
                for _, v in pairs(NewOpts) do AddOption(v, v) end
                CalculateSize()
            end
            function Dropdown:Remove(Value)
                local Name = tostring(Value)
                if Options[Name] then
                    if Options[Name].nodes and Options[Name].nodes[1] then
                        Options[Name].nodes[1]:Destroy()
                    end
                    Options[Name] = nil
                    if IsMulti then
                        Selected[Name] = nil
                        UpdateMultiLabel()
                    elseif tostring(Selected) == Name then
                        Selected = ""
                        ActiveLabel.Text = "..."
                    end
                    CalculateSize()
                end
            end
            function Dropdown:Set(Val)
                if IsMulti then
                    -- Val = table of values
                    Selected = {}
                    for _, op in pairs(Options) do
                        CreateTween({op.nodes[2], "BackgroundTransparency", 1, 0.2})
                        CreateTween({op.nodes[2], "Size", UDim2.fromOffset(4, 4), 0.2})
                        CreateTween({op.nodes[3], "TextTransparency", 0.4, 0.2})
                    end
                    if type(Val) == "table" then
                        for _, v in ipairs(Val) do
                            local Name = tostring(v)
                            if Options[Name] then
                                Selected[Name] = v
                                CreateTween({Options[Name].nodes[2], "BackgroundTransparency", 0, 0.2})
                                CreateTween({Options[Name].nodes[2], "Size", UDim2.fromOffset(4, 14), 0.2})
                                CreateTween({Options[Name].nodes[3], "TextTransparency", 0, 0.2})
                            end
                        end
                    end
                    UpdateMultiLabel()
                else
                    if Options[tostring(Val)] then
                        Selected = Val
